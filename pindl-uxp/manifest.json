{
  "id": "com.seamusmullan.pindl",
  "name": "pindl",
  "version": "1.0.0",
  "main": "index.html",
  "manifestVersion": 5,
  "host": [
    {
      "app": "premierepro",
      "minVersion": "25.0.0"
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": [
        "https://www.pinterest.com",
        "https://*.pinterest.com",
        "https://*.pinimg.com",
        "https://*.pinimg.com:443"
      ]
    },
    "localFileSystem": "request",
    "allowCodeGenerationFromStrings": false
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "pindl.panel",
      "label": { "default": "pindl" },
      "minimumSize": { "width": 320, "height": 380 },
      "preferredDockedSize": { "width": 360, "height": 520 },
      "preferredFloatingSize": { "width": 360, "height": 520 }
    }
  ]
}
